    </div>
  </section>
  <section class="h-auto scroll-mt-20 pt-5 container" id="consultations">
    <h2
      class="font-playfair text-center md:text-left text-3xl lg:text-4xl font-medium text-secondary pb-3 pt-5 md:pt-0"
    >
      Consultations
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 pb-10">
      <!-- Card 1 -->
      <div class="col-span-1">
        <Image
          src={klimt}
          alt="tableau de Gustav Klimt illustrant Athena et la philosophie dans la supervision"
          title="Athena de Gustav Klimt"
          class="w-full aspect-square object-cover mb-3 rounded-xl md:rounded-none"
        />

        <div
          class="bg-tertiary/90 text-white md:hover:scale-105 transition-transform duration-300 rounded-xl md:rounded-none"
        >
          <h3
            class="font-playfair lg:text-3xl text-2xl text-center lg:text-left font-medium pl-5 pt-1 lg:h-[9vh]"
          >
            Supervision
          </h3>

          <details class="group">
            <summary
              class="flex cursor-pointer items-end justify-center [&_::-webkit-details-marker]:hidden"
            >
              <svg
                class="w-15 h-15 transition-transform duration-300 group-open:-rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path

---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import botticeli from "../images/botticelli.jpg";
import klimt from "../images/klimt.jpg";
import rodin from "../images/rodin.jpg";
import thisperson from "../images/thispersondoesnotexist.jpg";
---

<Layout
  description="Psychothérapie philosophique à Toulouse avec Quelqu'un. Consultations individuelles, supervision et interventions en entreprise."
>
  <section
    class="flex flex-col justify-center items-center md:items-stretch md:min-h-dvh h-auto gap-5 font-playfair text-tertiary scroll-mt-20 container"
    id="accueil"
  >
    <div class="py-50 md:py-0 flex items-center">
      <img src="logo2.svg" alt="" class="h-16 w-auto md:hidden" />
      <h1 class="lg:text-4xl font-medium text-xl">
        Quelqu'un <span class="sr-only">
          Philosophe thérapeutique à Toulouse
        </span>
      </h1>
    </div>
    <h2 class="lg:text-3xl font-medium text-xl">
      Philosophe Thérapeutique <br />
      <span class="hidden md:block">à Toulouse</span>
    </h2>
    <h3 class="lg:text-2xl text-lg font-medium md:pl-10 pt-10 hidden md:block">
      "Philosopher, c'est bon pour la santé."
    </h3>
    <div
      class="lg:text-2xl text-lg text-center font-medium md:justify-end flex md:text-left"
    >
      <address class="flex flex-col not-italic">
        <a href="mailto:quelqu'un@gmail.com" class="hover:underline">
          quelqu'un@gmail.com
        </a>

        <a
          href="https://maps.google.com/?q=27+Rue+d'Alsace+Lorraine,+31000+Toulouse"
          target="_blank"
          class="hover:underline"
        >
          10 rue d’Alsace-Lorraine
        </a>

        <a href="tel:+33760287270" class="hover:underline"> 02.66.24.72.74 </a>
      </address>
    </div>
  </section>
  <section class="scroll-mt-20 container" id="presentation">
    <h2
      class="font-playfair text-center md:text-left text-3xl lg:text-4xl font-medium text-secondary pb-3 pt-5 md:pt-0"
    >
      Présentation
    </h2>
    <div class="md:grid-cols-3 grid gap-5">
      <Image
        src={thisperson}
        alt="Quelqu'un"
        title="Moi"
        class="md:col-span-1 md:col-start-3 rounded-xl md:rounded-none object-cover h-full w-full"
      />
      <p
        class="bg-tertiary/90 md:col-start-1 md:row-start-1 rounded-xl md:rounded-none text-white font-light p-5 font-opensans md:col-span-2 md:text-justify"
      >
        Lorem ipsum dolor sit, amet consectetur adipisicing elit. Exercitationem
        suscipit recusandae mollitia! Commodi, fuga eos nisi ad odio nesciunt
        itaque autem voluptatibus. Non cupiditate eum laboriosam excepturi
        laudantium labore unde. Repellendus facilis officiis ex nam odio
        doloremque labore possimus neque distinctio a voluptates eos incidunt
        quam repudiandae omnis nostrum modi blanditiis laboriosam, consectetur
        quidem pariatur impedit. Animi qui temporibus accusamus. Iste veritatis
        consequuntur, sint, autem impedit pariatur ipsa nesciunt ipsam
        dignissimos iure at consequatur fugiat animi quod asperiores distinctio
